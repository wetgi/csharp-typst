{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Render": {
    "TypstBinaryPath": "typst",
    "TimeoutSeconds": 30,
