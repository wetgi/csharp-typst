<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <RootNamespace>TypstRender.Service</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\TypstRender.Contracts\TypstRender.Contracts.csproj" />
  </ItemGroup>

  <!-- The typst binary is NOT carried by this project. The container image
       installs it onto PATH (see Dockerfile); locally, scripts/install-typst.sh
       provides it for `dotnet run`/tests. -->

</Project>
